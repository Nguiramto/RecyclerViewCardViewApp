<resources xmlns:tools="http://schemas.android.com/tools">
<!--Splash theme-->
    <style name="Theme.RecyclerViewCardViewApp.Splash" parent="Theme.SplashScreen">

        <item name="windowSplashScreenBackground">@color/black_red</item>
        <!-- Background color -->

        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <!-- Splash icon -->

        <item name="windowSplashScreenAnimationDuration">1000</item>
        <!-- Animation duration -->

        <item name="postSplashScreenTheme">@style/Theme.RecyclerViewCardViewApp</item>
        <!-- Main theme after splash -->

    </style>
    <!-- Base application theme. -->
    <style name="Base.Theme.RecyclerViewCardViewApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.RecyclerViewCardViewApp" parent="Base.Theme.RecyclerViewCardViewApp" />
</resources>